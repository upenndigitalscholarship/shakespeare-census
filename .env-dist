# Django settings
DJANGO_READ_DOT_ENV_FILE=True
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,0.0.0.0,127.0.0.1

# Database
DATABASE_URL=postgres://postgres@db:5432/shakespeare_census

# Redis (for production caching)
REDIS_URL=redis://redis:6379/0

# Email settings (local development uses mailpit)
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=Shakespeare Census <noreply@localhost>

# Optional: Use Docker internal IP for debug toolbar
USE_DOCKER=no

# Local development flag
LOCAL_DEVELOPMENT=True
